APP_NAME=SRS QA Forge API
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
FRONTEND_ORIGIN=http://127.0.0.1:5173
JWT_SECRET_KEY=change-this-secret-for-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=admin123
MAX_UPLOAD_SIZE_MB=25
TESTPLAN_GENERATOR_PROVIDER=ollama
OLLAMA_GENERATE_URL=http://localhost:11434/api/generate
LOCAL_AI_SRS_VISION_MODEL_2=qwen2.5:3b
OLLAMA_KEEP_ALIVE=15m
OLLAMA_NUM_GPU=-1
OLLAMA_MAIN_GPU=0
OLLAMA_NUM_CTX=8192
OLLAMA_TEMPERATURE=0.2
COLAB_SRS_BASE_URL=
COLAB_SRS_GENERATE_PATH=/generate-srs
COLAB_SRS_FALLBACK_PATHS=/generate-srs,/generate,/api/generate,/
COLAB_SRS_LOCAL_FALLBACK=true
COLAB_SRS_MODEL=qwen2.5:7b
COLAB_SRS_TEMPERATURE=0.2
COLAB_SRS_NUM_PREDICT=2500
COLAB_SRS_NUM_CTX=8192
COLAB_SRS_FORMAT=json
COLAB_SRS_TIMEOUT_SECONDS=600
MAX_PROMPT_DOCUMENT_CHARS=24000
